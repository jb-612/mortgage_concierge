# Example .env file for neo_advisor_service
# Copy this to .env and update values as needed.

# Port for the ADK API server (default: 8008)
PORT=8008

# Port for the ADK WEB server (default: 3008)
PORT=3008

# Port for the FastAPI server (default: 8003)
PORT=8003

# Google ADK model ID (default: gpt-4.1-nano)
ADK_MODEL_ID=gpt-4.1-nano

# URL to the loan calculator service OpenAPI spec
# FastAPI serves the spec at /openapi.json
LOAN_CALCULATOR_OPENAPI_URL=http://localhost:8001/openapi.json

# (Optional) OpenAI API key if using OpenAI models via ADK
OPENAI_API_KEY=

GOOGLE_API_KEY=

GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Path to Google Cloud service account JSON for ADK authentication
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json